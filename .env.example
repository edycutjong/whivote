# frontier-magicblock Environment Variables
# Copy to .env.local and fill in values

# Solana RPC URL
NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com

# MagicBlock Auth Token
# Private Ephemeral Rollups use an auth token rather than a traditional API key.
# Obtain it by:
# 1. Requesting a challenge from /v1/spl/challenge
# 2. Signing it with your wallet and calling /v1/spl/login to get a token
# Use the token as Authorization: Bearer <token>, or as ?token={authToken} on https://devnet-tee.magicblock.app
MAGICBLOCK_API_KEY=
